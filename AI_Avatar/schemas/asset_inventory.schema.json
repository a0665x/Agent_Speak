{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-speak.local/schemas/asset_inventory.schema.json",
  "title": "Verified Henry Asset Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "character",
    "composition",
    "canvas",
    "transition_source",
    "states"
  ],
  "properties": {
    "version": {
      "const": "1.0"
    },
    "character": {
      "const": "Henry"
    },
    "composition": {
      "const": "waist_up"
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "anchor_x", "anchor_y"],
      "properties": {
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "anchor_x": {"type": "number", "minimum": 0, "maximum": 1},
        "anchor_y": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "transition_source": {
      "$ref": "#/$defs/frameSource"
    },
    "states": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idle", "listening", "thinking", "speaking", "happy", "error"],
      "properties": {
        "idle": {"$ref": "#/$defs/frameSource"},
        "listening": {"$ref": "#/$defs/frameSource"},
        "thinking": {"$ref": "#/$defs/frameSource"},
        "speaking": {"$ref": "#/$defs/frameSource"},
        "happy": {"$ref": "#/$defs/frameSource"},
        "error": {"$ref": "#/$defs/frameSource"}
      }
    }
  },
  "$defs": {
    "frameSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sheet", "boxes"],
      "properties": {
        "sheet": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^/\\\\]+\\.png$"
        },
        "boxes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "prefixItems": [
              {"type": "integer", "minimum": 0},
              {"type": "integer", "minimum": 0},
              {"type": "integer", "minimum": 1},
              {"type": "integer", "minimum": 1}
            ],
            "items": false,
            "minItems": 4,
            "maxItems": 4
          }
        }
      }
    }
  }
}
