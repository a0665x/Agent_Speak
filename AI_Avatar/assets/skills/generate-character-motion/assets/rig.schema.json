{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "character_id",
    "review_status",
    "canvas",
    "joints",
    "bones",
    "locked_joints",
    "identity_regions",
    "s0_sha256"
  ],
  "properties": {
    "version": {"const": "1.0"},
    "character_id": {"type": "string", "minLength": 1},
    "review_status": {"enum": ["draft", "approved"]},
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "anchor_x", "anchor_y"],
      "properties": {
        "width": {"type": "integer", "minimum": 64},
        "height": {"type": "integer", "minimum": 64},
        "anchor_x": {"type": "number", "minimum": 0, "maximum": 1},
        "anchor_y": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "joints": {
      "type": "object",
      "minProperties": 2,
      "additionalProperties": {"$ref": "#/$defs/point"}
    },
    "bones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "prefixItems": [
          {"type": "string", "minLength": 1},
          {"type": "string", "minLength": 1}
        ],
        "items": false
      }
    },
    "locked_joints": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "identity_regions": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "s0_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {"type": "number", "minimum": 0, "maximum": 1},
        "y": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
