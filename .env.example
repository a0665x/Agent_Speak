# Safe default: accept connections from this machine only.
AGENT_SPEAK_HOST=127.0.0.1
AGENT_SPEAK_PORT=8765

# Private HTTPS access through Tailscale Serve; the app remains localhost-only.
AGENT_SPEAK_TAILSCALE_HTTPS_PORT=8765

# Private state remains in ignored project directories.
AGENT_SPEAK_DATA_DIR=data
AGENT_SPEAK_RUNTIME_DIR=runtime

# WAV requests are rejected before decoding when these limits are exceeded.
AGENT_SPEAK_MAX_AUDIO_BYTES=8388608
AGENT_SPEAK_MAX_AUDIO_SECONDS=30
AGENT_SPEAK_VAD_RMS_THRESHOLD=0.015

# Bounded in-memory and generated-artifact retention for the MVP.
AGENT_SPEAK_MAX_SESSIONS=100
AGENT_SPEAK_MAX_SESSION_EVENTS=128
AGENT_SPEAK_MAX_EVENT_QUEUE=64
AGENT_SPEAK_MAX_ARTIFACTS=100

# Local production speech providers. Faster-Whisper loads lazily on first turn.
AGENT_SPEAK_ASR_MODEL=small
AGENT_SPEAK_ASR_LANGUAGE=zh
AGENT_SPEAK_ASR_COMPUTE_TYPE=int8
AGENT_SPEAK_ASR_CPU_THREADS=4
AGENT_SPEAK_TTS_MODEL_PATH=models/piper/zh_CN-huayan-medium.onnx
